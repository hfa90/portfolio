# Browser-safe Supabase config
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server/CI only
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=sbp_xxx
SUPABASE_DB_PASSWORD=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Billing provider secrets - keep server-side only
BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Integration provider secrets - keep server-side only
WHATSAPP_PROVIDER=meta
WHATSAPP_ACCESS_TOKEN=replace-me
WHATSAPP_PHONE_NUMBER_ID=replace-me

# Analytics/document automation
ANALYTICS_SIGNING_SECRET=replace-me
DOCUMENT_SIGNING_SECRET=replace-me
